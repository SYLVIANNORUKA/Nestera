{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "setupFilesAfterEnv": ["<rootDir>/jest-e2e-setup.ts"],
  "collectCoverage": false,
  "coverageDirectory": "../coverage/e2e",
  "coverageReporters": ["text", "lcov", "html"],
  "collectCoverageFrom": [
    "../src/**/*.ts",
    "!../src/**/*.spec.ts",
    "!../src/**/*.module.ts",
    "!../src/main.ts",
    "!../src/migrations/**",
    "!../src/**/*.entity.ts"
  ],
  "coverageThreshold": {
    "global": {
      "branches": 60,
      "functions": 70,
      "lines": 75,
      "statements": 75
    }
  },
  "testTimeout": 30000,
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/../src/$1"
  }
}
